# ==========================================
# SinergIA OS - Production Environment Config Template
# Copy this file to .env.local for local development, or set these 
# environment variables in your Hosting provider (e.g. Firebase App Hosting).
# ==========================================

# 1. FIREBASE CONFIGURATION (Web SDK)
# Required for client-side Auth, Firestore, and storage.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# 2. WEBHOOK ORCHESTRATION CONFIGURATION (n8n / Make.com / Clay)
# Webhook URL for general lead generation (ROI Calculator and Chatbot)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://n8n.sinergia.business/webhook/lead-capture

# Webhook URL for B2B Client Applications (/apply)
N8N_APPLY_WEBHOOK_URL=https://n8n.sinergia.business/webhook/apply-leads

# Webhook URL for SinergiaAudit (Domain scan)
NEXT_PUBLIC_AUDIT_WEBHOOK_URL=https://n8n.sinergia.business/webhook/domain-scan

# 3. ANALYTICS & PIXELS TRACKING (Optional)
# Google Analytics 4 Tag ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Facebook Pixel Tracking ID
NEXT_PUBLIC_FB_PIXEL_ID=123456789012345
# Hotjar Site ID
NEXT_PUBLIC_HOTJAR_ID=1234567
# LinkedIn Insight Tag Conversion ID
NEXT_PUBLIC_LINKEDIN_CONVERSION_ID=1234567
